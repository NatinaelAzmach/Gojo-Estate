# ============================================================
# HOMELY — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------------
# Supabase project URL
# Found in: Supabase Dashboard → Project Settings → API → Project URL
# ------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# ------------------------------------------------------------------
# Supabase anonymous (public) key
# Safe to expose in the browser. Enforces RLS on all requests.
# Found in: Supabase Dashboard → Project Settings → API → anon / public
# ------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ------------------------------------------------------------------
# Supabase service role key
# KEEP SECRET — bypasses RLS. Used only in server-side code
# (Server Actions, API routes, admin operations).
# Found in: Supabase Dashboard → Project Settings → API → service_role
# ------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
